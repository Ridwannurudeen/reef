# Copy to .env and fill in. NEVER commit .env.

# Deployer key (Mantle Sepolia account funded from https://faucet.sepolia.mantle.xyz)
PRIVATE_KEY=0x...

# Mantle Sepolia (chain 5003)
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Mantle Mainnet (chain 5000) - used only for the demo instance with $10-20 USDY
MANTLE_RPC=https://rpc.mantle.xyz

# Mantlescan API key (for forge verify) - https://mantlescan.xyz
MANTLESCAN_API_KEY=

# Allora API - https://developer.allora.network
ALLORA_API_KEY=

# Z.ai API (for GLM-5.1 inference in reference agents) - https://docs.z.ai
ZAI_API_KEY=

# --- Verified mainnet addresses (do not change; pin these in deployments/) ---
# Ondo USDY (Mantle mainnet, ERC-20, 18 decimals, non-rebasing)
USDY_MAINNET=0x5bE26527e817998A7206475496fDE1E68957c5A6
# Ondo mUSD wrapper (rebasing)
MUSD_MAINNET=0xab575258d37EaA5C8956EfABe71F4eE8F6397cF3
# mETH L2 token on Mantle (bridged; staking lives on L1 Ethereum)
METH_MANTLE=0xcDA86A272531e8640cD7F1a92c01839911B90bb0

# --- Optional ---
# TREASURY=0x...        # protocol fee recipient (defaults to deployer)
