# Compiler files
cache/
out/

# Commonly ignored directories
.logs/
.ignore/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs (keep README screenshots; ignore any generated docs)
docs/*
!docs/*.png

# Generated public-API snapshots (built by agents/scripts/api_snapshot.py on the VPS)
ui/api/

# Local BYOA agent state generated by create-reef-agent/
create-reef-agent/agent.json
create-reef-agent/agents/
create-reef-agent/out/

# Dotenv file
.env
.env.*
!.env.example
